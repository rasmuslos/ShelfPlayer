    "By using ShelfPlayer you agree to the [Terms of Service](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)": {
      "comment": "A disclaimer shown on the welcome screen linking to the Terms of Service.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit der Nutzung von ShelfPlayer stimmst du den [Nutzungsbedingungen](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md) zu"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιώντας το ShelfPlayer αποδέχεστε τους [Όρους χρήσης](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By using ShelfPlayer you agree to the [Terms of Service](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En utilisant ShelfPlayer, vous acceptez les [conditions d'utilisation](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizzando ShelfPlayer accetti le [Condizioni di servizio](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door ShelfPlayer te gebruiken ga je akkoord met de [servicevoorwaarden](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используя ShelfPlayer, вы соглашаетесь с [Условиями использования](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Genom att använda ShelfPlayer godkänner du [användarvillkoren](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовуючи ShelfPlayer, ви погоджуєтеся з [Умовами використання](https://github.com/rasmuslos/ShelfPlayer/blob/main/ToS.md)"
