    "item.convenienceDownload.description": {
      "comment": "A description of the convenience download feature.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer lädt basierend auf deinen Filter- & Sortierungseinstellungen und dem konfigurierten Wert herunter. "
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το ShelfPlayer θα κατεβάσει στοιχεία βάσει των προτιμήσεων φίλτρου και ταξινόμησης που έχετε ρυθμίσει, στον αριθμό που ορίζετε."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer will download items based on the filter & sort preferences you configured, as well as the amount you specify."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer téléchargera les éléments en fonction des préférences de filtre et de tri que vous avez configurées, ainsi que de la quantité que vous spécifiez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer scaricherà gli elementi in base ai filtri e ai criteri di ordinamento configurati, nella quantità che indichi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer downloadt items op basis van je filter- en sorteervoorkeuren, in het aantal dat je opgeeft."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer произведёт загрузку полагаясь на настройки фильтрации и сортировки, и в том количестве, которое вы указали."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer laddar ned objekt baserat på vald filtrering och sortering, samt den valda mängden."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer завантажить елементи відповідно до ваших налаштувань фільтрації та сортування, а також у вказаній кількості."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer 将根据您配置的过滤和排序偏好以及您指定的数量下载项目。"
          }
        }
      }
    },
