    "connection.outdatedServer": {
      "comment": "A warning message that a connection is using an outdated server.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie verwenden eine veraltete Server-Version! ShelfPlayer funktioniert möglicherweise nicht wie vorgesehen, und es wird nur eingeschränkter Support angeboten. Bitte aktualisieren Sie Ihren Server, bevor Sie ein GitHub-Issue öffnen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιείτε μια παρωχημένη έκδοση διακομιστή! Το ShelfPlayer ενδέχεται να μη λειτουργεί σωστά και παρέχεται περιορισμένη υποστήριξη. Ενημερώστε τον διακομιστή σας πριν δημιουργήσετε θέμα στο GitHub."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are using an outdated server version! ShelfPlayer might not work as intended and only limited support is provided. Please update your server before opening a GitHub issue."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous utilisez une version obsolète du serveur ! ShelfPlayer pourrait ne pas fonctionner correctement et seul un support limité est fourni. Veuillez mettre à jour votre serveur avant d’ouvrir un ticket sur GitHub."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Stai usando una versione obsoleta del server! ShelfPlayer potrebbe non funzionare correttamente e il supporto è limitato. Aggiorna il server prima di aprire una segnalazione su GitHub."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je gebruikt een verouderde serverversie! ShelfPlayer werkt mogelijk niet zoals bedoeld en er is slechts beperkte ondersteuning. Werk je server bij voordat je een GitHub-melding maakt."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы используете устарешую версию сервера! ShelfPlayer может работать некорректно, и поддержка ограничена. Пожалуйста, обновите сервере перед тем как открыть запрос на GitHub."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du använder en föråldrad serverversion! ShelfPlayer kanske inte fungerar som det är tänkt, och endast begränsat stöd tillhandahålls. Uppdatera din server innan du öppnar ett ärende på GitHub."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви використовуєте застарілу версію сервера! ShelfPlayer може працювати некоректно, і надається лише обмежена підтримка. Оновіть сервер перед тим, як створювати звернення на GitHub."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您正在使用过时的服务器版本！ShelfPlayer 可能无法正常运行，且仅提供有限的支持。在创建 GitHub 问题之前，请先更新您的服务器。"
          }
        }
      }
    },
