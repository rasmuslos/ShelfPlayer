    "playback.upNextQueue.tip.description": {
      "comment": "A description of the up-next queue tip.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Als nächstes kann in den Einstellungen für Podcasts und Serien konfiguriert werden. Es kann auch in der Einstellungs-App deaktiviert werden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η ουρά «Επόμενο» μπορεί να διαμορφωθεί στις ρυθμίσεις podcast και σειρών. Μπορεί επίσης να απενεργοποιηθεί στις ρυθμίσεις."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The up next queue can be configured in the podcast & series settings. It can also be disabled in the settings app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La file d'attente suivante peut être configurée dans les paramètres des podcasts et séries. Elle peut également être désactivée dans l'application Paramètres."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La coda \"Prossimo\" può essere configurata nelle impostazioni di podcast e serie. Può anche essere disabilitata nelle impostazioni."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De Volgende-wachtrij kan worden geconfigureerd in de podcast- en serie-instellingen, of worden uitgeschakeld in de instellingen-app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Порядок очереди можно настроить в конфигурации подрастов и серий. Или эта функция может быть отключена в настройках приложения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kön för näst på tur kan konfigureras i inställningarna för podcast och serier. Den kan också avaktiveras i appen för inställninga."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Чергу 'Далі' можна налаштувати в параметрах подкастів та серій. Також її можна відключити в додатку «Налаштування»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "播放队列可以在播客或者系列中设置，也可以在设置中禁用"
          }
        }
      }
    },
