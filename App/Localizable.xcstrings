          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η εκκαθάριση της κρυφής μνήμης προόδου ενδέχεται να οδηγήσει σε απώλεια της τοπικά αποθηκευμένης προόδου."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Purging the progress cache may result in the loss of locally cached progress."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La suppression du cache de progression peut entraîner la perte de la progression mise en cache localement."
