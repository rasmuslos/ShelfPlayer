    "home.customization.footer": {
      "comment": "A footer explaining the available home customization options.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ordne Abschnitte per Drag & Drop neu an, blende sie mit dem Augensymbol aus oder streiche, um sie zu entfernen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Σύρετε για αναδιάταξη ενοτήτων, αγγίξτε το εικονίδιο ματιού για απόκρυψη ή σύρετε για αφαίρεση."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag to reorder sections, tap the eye icon to hide one, or swipe to remove it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glissez pour réorganiser les sections, touchez l'œil pour en masquer une, ou balayez pour la supprimer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trascina per riordinare le sezioni, tocca l'occhio per nasconderle o scorri per rimuoverle."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sleep om secties te herschikken, tik op het oog om er een te verbergen, of veeg om te verwijderen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетаскивайте, чтобы менять порядок разделов, нажимайте иконку глаза, чтобы скрыть, или смахивайте, чтобы удалить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dra för att ändra ordning på sektioner, tryck på ögat för att dölja eller svep för att ta bort."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетягуйте, щоб упорядкувати розділи, торкніться ока, щоб приховати, або змахніть, щоб видалити."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动以重新排序分组，点按眼睛图标可隐藏，左滑可移除。"
          }
        }
      }
    },
