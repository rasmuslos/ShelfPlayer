    "error.unavailable.text": {
      "comment": "A description shown when content is unavailable due to an error.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelle sicher, dass das iPhone mit dem Internet verbunden ist und ShelfPlayer die Audiobookshelf-Instanz erreichen kann."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Βεβαιωθείτε ότι η συσκευή σας είναι συνδεδεμένη στο διαδίκτυο και ότι το ShelfPlayer μπορεί να φτάσει στην εγκατάσταση Audiobookshelf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make sure your device is connected to the internet and ShelfPlayer is able to reach your Audiobookshelf instance."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assurez-vous que votre appareil est connecté à Internet et que ShelfPlayer est capable d'atteindre votre instance Audiobookshelf."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifica che il dispositivo sia connesso a internet e che ShelfPlayer possa raggiungere la tua istanza Audiobookshelf."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zorg dat je apparaat verbonden is met internet en dat ShelfPlayer je Audiobookshelf-installatie kan bereiken."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Убедитесь, что устройство подключено к интернету и ShelfPlayer может общаться с Audiobookshelf."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Se till att din enhet är ansluten till internet och att ShelfPlayer kan nå din Audiobookshelf-instans."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Переконайтеся, що ваш пристрій підключено до інтернету, і ShelfPlayer може зв’язатися з вашим екземпляром Audiobookshelf."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请确认您的设备已连接互联网，并且可以访问你的 AudiobookShelf服务器"
          }
        }
      }
    },
