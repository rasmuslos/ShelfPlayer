    "warning.convenienceDownloadManaged": {
      "comment": "Warning message when a convenience download is managed by the system.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Objekt, welches entfernt werden soll, ist automatisch heruntergeladen. Wenn es entfernt wird, ohne die Konfiguration zu entfernen, wird es eventuell erneut heruntergeladen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το στοιχείο που προσπαθήσατε να αφαιρέσετε κατεβαίνει αυτόματα. Αν δεν αφαιρέσετε τη διαμόρφωση, ενδέχεται να ληφθεί ξανά."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The item you tried to remove is automatically downloaded. If you do not remove the configuration, it might be downloaded again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'élément que vous avez tenté de supprimer a été téléchargé automatiquement. Si vous ne supprimez pas la configuration, il risque d'être téléchargée à nouveau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'elemento che hai provato a rimuovere viene scaricato automaticamente. Se non rimuovi la configurazione, potrebbe essere scaricato di nuovo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het item dat je wilde verwijderen wordt automatisch gedownload. Als je de configuratie niet verwijdert, wordt het mogelijk opnieuw gedownload."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объект, который вы пытаетесь удалить, загружается автоматически. Если не удалить соответствующую настройку, он может быть загружен снова."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Objektet du försökte ta bort är automatiskt nedladdat. Om du inte tar bort konfigurationen kan det laddas ned igen."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Елемент, який ви намагаєтесь видалити, завантажується автоматично. Якщо ви не видалите налаштування, його може бути завантажено знову."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您尝试移除的项目是自动下载的。如果不移除相关配置，该项目可能会再次被下载。\n"
          }
        }
      }
    },
    "warning.playbackDownload.activeDownload": {
      "comment": "Warning message displayed when starting playback while a download is active.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Objekt, das abgespielt werden soll, wird gerade heruntergeladen. Download abbrechen und mit der Wiedergabe beginnen?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το στοιχείο που προσπαθήσατε να αναπαραγάγετε κατεβαίνει αυτήν τη στιγμή. Ακύρωση λήψης και έναρξη αναπαραγωγής;"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The item you tried to play is currently being downloaded. Abort download and begin playback?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'élément que vous avez essayé de lire est en cours de téléchargement. Voulez-vous interrompre le téléchargement et commencer la lecture?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'elemento che hai provato a riprodurre è attualmente in download. Interrompere il download e avviare la riproduzione?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het item dat je wilde afspelen wordt momenteel gedownload. Download afbreken en afspelen beginnen?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объект, который Вы пытаетесь воспроизвести сейчас загружается. Прервать загрузку или начать воспроизведение?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Objektet du försökte spela laddas för närvarande ned. Avbryt nedladdningen och påbörja uppspelning?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Елемент, який ви намагаєтеся відтворити, наразі завантажується. Скасувати завантаження та почати відтворення?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您尝试播放的项目当前正在下载。是否中止下载并开始播放？"
          }
        }
      }
    },
    "warning.playbackDownload.activePlayback": {
      "comment": "Alert message when starting playback while a download is active.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Objekt, das heruntergeladen werden soll, wird gerade abgespielt. Wiedergabe beenden und Download starten?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το στοιχείο που προσπαθήσατε να κατεβάσετε αναπαράγεται αυτήν τη στιγμή. Διακοπή αναπαραγωγής και έναρξη λήψης;"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The item you tried to download is currently being played. End playback and begin download?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'élément que vous essayez de télécharger est en cours de lecture. Voulez-vous arrêter la lecture et commencer le téléchargement?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'elemento che hai provato a scaricare è attualmente in riproduzione. Terminare la riproduzione e avviare il download?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het item dat je wilde downloaden wordt momenteel afgespeeld. Weergave beëindigen en downloaden starten?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объект, который Вы пытаетесь скачать сейчас воспроизводится. Прервать воспроизведение или начать загрузку?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Objektet du försökte ladda ned spelas för närvarande. Avbryt uppspelningen och påbörja nedladdningen?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Елемент, який ви намагаєтеся завантажити, наразі відтворюється. Завершити відтворення та почати завантаження?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您尝试下载的项目当前正在播放。是否结束播放并开始下载？"
          }
        }
      }
    },
    "warning.playbackDownload.removeDownload": {
      "comment": "Warning message when a download is removed while a song is playing.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Element, das entfernt werden soll, wird derzeit abgespielt. Wiedergabe beenden und Download entfernen?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το στοιχείο που προσπαθήσατε να αφαιρέσετε αναπαράγεται αυτήν τη στιγμή. Διακοπή αναπαραγωγής και αφαίρεση λήψης;"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The item you tried to remove is currently being played. End playback and remove download?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'élément que vous avez essayé de supprimer est en cours de lecture. Arrêter la lecture et supprimer le téléchargement?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'elemento che hai provato a rimuovere è attualmente in riproduzione. Terminare la riproduzione e rimuovere il download?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het item dat je wilde verwijderen wordt momenteel afgespeeld. Weergave beëindigen en download verwijderen?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Объект, который Вы пытаетесь удалить сейчас воспроизводится. Закончить воспроизведение и удалить?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Objektet du försökte ta bort spelas för närvarande. Avbryt uppspelningen och ta bort nedladdningen?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Елемент, який ви намагаєтеся видалити, наразі відтворюється. Завершити відтворення та видалити завантаження?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您尝试移除的项目当前正在播放。是否结束播放并移除下载？\n"
          }
        }
      }
    }
  },
