    "NSMicrophoneUsageDescription": {
      "comment": "Privacy - Microphone Usage Description",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer verwendet das Mikrofon nicht"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το ShelfPlayer δεν χρησιμοποιεί το μικρόφωνο"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer does not use the microphone"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer n'utilise pas le microphone"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer non utilizza il microfono"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer gebruikt de microfoon niet"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer не использует микрофон"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer använder inte mikrofonen"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer не використовує мікрофон"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ShelfPlayer 不使用麦克风"
          }
        }
      }
    },
    "NSSiriUsageDescription": {
      "comment": "Privacy - Siri Usage Description",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Steuere die Wiedergabe mit Siri, erstelle Lesezeichen und mehr."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιήστε το Siri για τον έλεγχο της αναπαραγωγής, τη δημιουργία σελιδοδεικτών και άλλα."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Siri to control playback, create bookmarks, and more."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez Siri pour contrôler la lecture, créer des signets et plus encore."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa Siri per controllare la riproduzione, creare segnalibri e molto altro."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik Siri om de weergave te bedienen, bladwijzers te maken en meer."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте Siri для управления воспроизведением, создания закладок и других действий."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd Siri för att styra uppspelningen, skapa bokmärken och mer."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Керуйте відтворенням за допомогою Siri, створюйте закладки тощо."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 Siri 控制播放、创建书签等。"
          }
        }
      }
    },
