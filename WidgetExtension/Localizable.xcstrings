    "widget.listenNow.description": {
      "comment": "A description of the Listen Now widget.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt die zuletzt gespielten, nicht abgeschlossenen Objekte aus allen Bibliotheken"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εμφανίζει πρόσφατα αναπαραγόμενα, μη ολοκληρωμένα στοιχεία από όλες τις βιβλιοθήκες."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows recently played, unfinished items from all libraries."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Épisodes récemment écoutés, éléments inachevées de toutes les bibliothèques."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra elementi ascoltati di recente e non terminati da tutte le librerie."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toont recent afgespeelde, onvoltooide items uit alle bibliotheken."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показать недавно воспроизведённые и не завершённые фргаменты из всех библиотек."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Visar nyligen spelade, ofärdiga objekt från alla bibliotek."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Показує нещодавно відтворені, незавершені елементи з усіх бібліотек."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示所有媒体库中最近播放的、未完成的项目。"
          }
        }
      }
    },
