    "widget.start.description": {
      "comment": "A description of the widget.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiele das angegebene Element ab, oder wechsle zum ersten „Jetzt anhören“-Vorschlag, falls keiner ausgewählt ist.\n"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αναπαραγωγή του επιλεγμένου στοιχείου ή του πρώτου προτεινόμενου από το «Άκου τώρα» αν δεν έχει επιλεγεί κανένα."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Play the specified item or fall back to the first listen now suggestion if none is selected."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lire l'élément spécifié, ou revenir à la première suggestion « Écouter maintenant » si aucun n'est sélectionné."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduce l'elemento specificato o il primo suggerimento di Ascolta ora se non è selezionato alcun elemento."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Speelt het gekozen item af, of het eerste Luister nu-voorstel als er niets is geselecteerd."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Воспроизведите указанный элемент или откатитесь к первому предложению «Слушать сейчас», если ни один не выбран.\n"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spela upp den angivna posten, eller återgå till den första “Lyssna nu”-förslaget om inget har valts."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відтворіть вказаний пункт або поверніться до першої пропозиції «Прослухати зараз», якщо жоден не вибрано."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "播放所选项目，或在未选择任何项目时回退到第一条“立即聆听”建议。\n"
          }
        }
      }
